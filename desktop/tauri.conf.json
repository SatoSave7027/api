{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SatoSave Vault",
  "version": "1.0.0",
  "identifier": "com.satosave.vault",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SatoSave Vault",
        "width": 1280,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
