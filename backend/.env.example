APP_NAME=SatoSave Vault API
ENVIRONMENT=development

# PostgreSQL connection string (psycopg3 dialect)
DATABASE_URL=postgresql+psycopg://satosave:satosave@localhost:5432/satosave_vault

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-long-random-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
SESSION_IDLE_HOURS=5
SESSION_LIFETIME_DAYS=30

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
OTP_SECRET=replace-with-a-long-random-otp-secret-min-32-chars
OTP_TTL_MINUTES=10
OTP_RESEND_SECONDS=60
OTP_HOURLY_LIMIT=5

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-a-fernet-key

# Comma-separated allowed frontend origins
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173,tauri://localhost

# SMTP for OTP delivery (example uses Mailtrap sandbox)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=mailtrap-username
SMTP_PASSWORD=mailtrap-password
SMTP_FROM_EMAIL=no-reply@satosave.local
SMTP_USE_TLS=true

PUBLIC_UPLOAD_BASE_URL=/media
UPLOAD_MAX_MB=5
