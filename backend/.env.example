# --- Application ---
APP_NAME=SatoSave Vault
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database ---
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://satosave:satosave@localhost:5432/satosave

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=300
SESSION_IDLE_TIMEOUT_MINUTES=300

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-fernet-key

# --- OTP ---
OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_COOLDOWN_SECONDS=60

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:1420,http://localhost:8081,http://localhost:19006

# --- Email (SMTP) ---
# Provider can be: smtp | resend | console (console only for emergencies / CI)
EMAIL_PROVIDER=smtp
EMAIL_FROM=SatoSave Vault <no-reply@satosave.local>
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=replace-me
SMTP_PASSWORD=replace-me
SMTP_USE_TLS=true

# --- Resend (alternative provider) ---
RESEND_API_KEY=

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=5242880
PUBLIC_BASE_URL=http://localhost:8000
