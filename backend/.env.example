APP_NAME=SatoSave Vault API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/satosave_vault
JWT_SECRET_KEY=change-this-super-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
SESSION_IDLE_TIMEOUT_HOURS=5
SESSION_MAX_DAYS=30
OTP_EXPIRATION_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_REQUEST_COOLDOWN_SECONDS=60
OTP_REQUEST_LIMIT_PER_HOUR=5
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password
SMTP_FROM_EMAIL=no-reply@satosave.local
SMTP_USE_TLS=true
SMTP_USE_SSL=false
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:1420,http://localhost:19006
ENCRYPTION_KEY=replace-with-a-valid-fernet-key
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=8
TOKEN_COOKIE_NAME=satosave_refresh_token
