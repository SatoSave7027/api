DATABASE_URL=postgresql://user:password@localhost:5432/satosave
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_HOURS=5
ENCRYPTION_KEY=your-32-byte-fernet-encryption-key-base64=
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:1420
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Email (SMTP option)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASSWORD=your-mailtrap-password
SMTP_FROM=noreply@satosave.app
SMTP_TLS=true

# Email (Resend option - preferred)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@satosave.app
EMAIL_PROVIDER=smtp

OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_HOUR=5
